            "url": "{{baseUrl}}/api/medical-records/{{medicalRecordId}}"
          }
        },
        {
          "name": "26c. Add Medical Record (CREATE)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var json = pm.response.json();",
                "  if (json.id) pm.collectionVariables.set('medicalRecordId', json.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{patientToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Blood Test Report\",\n  \"type\": \"LAB_REPORT\",\n  \"doctorName\": \"Dr. Priya Menon\",\n  \"notes\": \"All values within normal range\",\n  \"fileUrl\": \"https://example.com/reports/blood-test.pdf\"\n}"
            },
            "url": "{{baseUrl}}/api/medical-records/user/{{userId}}"
          }
        }
      ]
    }
  ]
