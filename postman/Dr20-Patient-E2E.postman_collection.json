            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{patientToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"pravin\",\n  \"lastName\": \"av\",\n  \"email\": \"pravin.updated@dr20.com\",\n  \"dateOfBirth\": \"1998-01-15\",\n  \"gender\": \"Male\",\n  \"bloodGroup\": \"O+\",\n  \"address\": \"Tambaram, Chennai\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/profile/{{userId}}"
          }
