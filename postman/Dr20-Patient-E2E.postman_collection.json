          }
        },
        {
          "name": "8. List Doctors — Consult at ₹20",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "function localDateStr(offsetDays) {",
                "  var d = new Date();",
                "  d.setDate(d.getDate() + offsetDays);",
                "  var y = d.getFullYear();",
                "  var m = String(d.getMonth() + 1).padStart(2, '0');",
                "  var day = String(d.getDate()).padStart(2, '0');",
                "  return y + '-' + m + '-' + day;",
                "}",
                "if (pm.response.code === 200) {",
                "  var doctors = pm.response.json();",
                "  if (Array.isArray(doctors) && doctors.length > 0) {",
                "    pm.collectionVariables.set('doctorId', doctors[0].id);",
                "    pm.collectionVariables.set('appointmentDate', localDateStr(1));",
                "    pm.collectionVariables.set('rescheduleDate', localDateStr(2));",
                "  }",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/doctors?maxFee=20&clinicType=DR20_CLINIC&availableToday=true"
          }
        },
        {
          "name": "8b. List Doctors — Private Clinics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/doctors?clinicType=PRIVATE_CLINIC&sort=topRated"
          }
        },
        {
          "name": "8c. List Doctors — Nearest",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/doctors?sort=nearest&latitude=12.9249&longitude=80.1000"
          }
        },
        {
          "name": "9. Doctor Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/doctors/{{doctorId}}/detail"
          }
        },
        {
          "name": "10. Doctor Slots",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var slots = pm.response.json();",
                "  if (Array.isArray(slots) && slots.length > 0) {",
                "    pm.collectionVariables.set('appointmentTime', slots[0]);",
                "    if (slots.length > 1) pm.collectionVariables.set('rescheduleTime', slots[1]);",
                "  }",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/doctors/{{doctorId}}/slots?date={{appointmentDate}}"
          }
