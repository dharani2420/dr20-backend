{
  "info": {
    "name": "Dr.20 Patient App (E2E)",
    "description": "Full patient E2E + CRUD coverage.\n\nFolders: Auth/Profile, Discovery, Book & Pay, Appointments CRUD, Payments, Family CRUD, Notifications, Reviews, Medical Records.\n\nVariables: baseUrl, patientPhone, patientToken, userId, doctorId, appointmentId, cancelAppointmentId, completedAppointmentId, orderId, paymentId, appointmentDate, appointmentTime, rescheduleDate, rescheduleTime, familyMemberId, notificationId, medicalRecordId\n\nOTP: Render Logs. Auth tab = No Auth; one Authorization header on protected calls.\n\nSeed patient: phone 9876543210. Completed review: staff must complete appointment first (Staff collection).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://dr20-backend.onrender.com" },
    { "key": "newPatientPhone", "value": "9444444444" },
    { "key": "patientPhone", "value": "9876543210" },
    { "key": "patientToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "doctorId", "value": "" },
    { "key": "appointmentId", "value": "" },
    { "key": "cancelAppointmentId", "value": "" },
    { "key": "completedAppointmentId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "appointmentDate", "value": "" },
    { "key": "appointmentTime", "value": "09:00 AM" },
    { "key": "rescheduleDate", "value": "" },
    { "key": "rescheduleTime", "value": "10:00 AM" },
    { "key": "familyMemberId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "medicalRecordId", "value": "" }
  ],
  "item": [
    {
      "name": "01 — Auth & Profile",
      "item": [
        {
          "name": "1. Send OTP (Login)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{patientPhone}}\"\n}" },
            "url": "{{baseUrl}}/api/auth/send-otp"
          }
        },
        {
          "name": "1b. Send OTP (New Signup)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  pm.collectionVariables.set('patientPhone', pm.collectionVariables.get('newPatientPhone'));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{newPatientPhone}}\"\n}" },
            "url": "{{baseUrl}}/api/auth/send-otp"
          }
        },
        {
          "name": "1c. Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{patientPhone}}\"\n}" },
            "url": "{{baseUrl}}/api/auth/resend-otp"
          }
        },
        {
          "name": "2. Verify OTP",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var json = pm.response.json();",
                "  if (json.token) pm.collectionVariables.set('patientToken', json.token);",
                "  if (json.userId) pm.collectionVariables.set('userId', json.userId);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{patientPhone}}\",\n  \"otp\": \"PASTE_OTP_FROM_LOGS\"\n}" },
            "url": "{{baseUrl}}/api/auth/verify-otp"
          }
        },
        {
          "name": "3. Complete Profile (CREATE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{patientToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"pravin\",\n  \"lastName\": \"av\",\n  \"email\": \"pravin@dr20.com\",\n  \"dateOfBirth\": \"1998-01-15\",\n  \"gender\": \"Male\",\n  \"bloodGroup\": \"O+\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/complete-profile"
          }
        },
        {
          "name": "20. Get Profile (READ)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{patientToken}}" }],
            "url": "{{baseUrl}}/api/auth/profile/{{userId}}"
          }
        },
        {
          "name": "20b. Update Profile (UPDATE)",
