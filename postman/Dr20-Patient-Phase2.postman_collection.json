{
  "info": {
    "name": "Dr.20 Patient App (Figma Batch 1)",
    "description": "Batch 1 only — doctor/nurse discovery screens from Figma.\n\nScreens: P1 Doctor Search & Listing, P2 Doctor Profile.\n\nBatch 2 (auth, home, booking, payment) will be added when remaining screenshots arrive.\n\nVariables: baseUrl, doctorId\n\nNo auth required for public doctor listing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://dr20-backend.onrender.com" },
    { "key": "doctorId", "value": "" }
  ],
  "item": [
    {
      "name": "P1. List Doctors (all)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var doctors = pm.response.json();",
              "  if (Array.isArray(doctors) && doctors.length > 0 && doctors[0].id) {",
              "    pm.collectionVariables.set('doctorId', doctors[0].id);",
              "    console.log('doctorId saved: ' + doctors[0].id);",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/doctors"
      }
    },
    {
      "name": "P1b. List Doctors — filters (rating, availability)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/doctors?minRating=4.5&availableToday=true"
      }
    },
    {
      "name": "P1c. Search Doctors",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/doctors/search?q=Priya"
      }
    },
    {
      "name": "P1d. List Doctors — gender filter",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/doctors?gender=Female"
      }
    },
    {
      "name": "P2. Doctor Profile",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/doctors/{{doctorId}}"
      }
    },
    {
      "name": "P2b. Doctor Slots (for Book now — batch 2)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/doctors/{{doctorId}}/slots?date=2026-07-10"
      }
    }
  ]
}
