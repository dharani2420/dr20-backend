{
  "info": {
    "name": "Dr.20 Staff App (E2E)",
    "description": "Full staff E2E + CRUD coverage.\n\nFolders: Auth/Registration, Verification/Documents, Dashboard/Bookings, Appointments (Verify/Complete), Schedule/Availability, Profile, Earnings.\n\nVariables: baseUrl, staffPhone, newStaffPhone, staffToken, userId, linkedProfileId, appointmentId, homeVisitAppointmentId, scheduleFrom, scheduleTo, scheduleDate, verifyToken, qrData\n\nOTP: Render Logs. Auth tab = No Auth; one Authorization header on protected calls.\n\nSeed staff: phone 9123456781. Verify token 07 / QR DR20-SEED001. Pair with Patient E2E for book → staff verify flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://dr20-backend.onrender.com" },
    { "key": "staffPhone", "value": "9123456781" },
    { "key": "newStaffPhone", "value": "9222222222" },
    { "key": "adminStaffPhone", "value": "9111111111" },
    { "key": "staffToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "linkedProfileId", "value": "" },
    { "key": "appointmentId", "value": "" },
    { "key": "homeVisitAppointmentId", "value": "" },
    { "key": "scheduleFrom", "value": "" },
    { "key": "scheduleTo", "value": "" },
    { "key": "scheduleDate", "value": "" },
    { "key": "verifyToken", "value": "07" },
    { "key": "qrData", "value": "DR20-SEED001" }
  ],
  "item": [
    {
      "name": "01 — Auth & Registration",
      "item": [
        {
          "name": "0a. Staff Self Register (CREATE)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{newStaffPhone}}\",\n  \"profession\": \"DOCTOR\",\n  \"firstName\": \"Anita\",\n  \"lastName\": \"Sharma\",\n  \"email\": \"anita@dr20.com\"\n}"
            },
            "url": "{{baseUrl}}/api/staff/auth/register"
          }
        },
        {
          "name": "0b. Admin Create Staff (CREATE — optional)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{adminStaffPhone}}\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Doctor\",\n  \"profession\": \"DOCTOR\",\n  \"specialization\": \"Dermatology\",\n  \"consultationFee\": \"700\",\n  \"clinicName\": \"Test Clinic\",\n  \"clinicAddress\": \"Test Address\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/staff"
          }
        },
        {
          "name": "1. Send OTP (Login)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{staffPhone}}\"\n}" },
            "url": "{{baseUrl}}/api/staff/auth/send-otp"
          }
        },
        {
          "name": "1b. Send OTP (New Staff Signup)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  pm.collectionVariables.set('staffPhone', pm.collectionVariables.get('newStaffPhone'));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{newStaffPhone}}\"\n}" },
            "url": "{{baseUrl}}/api/staff/auth/send-otp"
          }
        },
        {
          "name": "1c. Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{staffPhone}}\"\n}" },
            "url": "{{baseUrl}}/api/staff/auth/resend-otp"
          }
        },
        {
          "name": "2. Verify OTP",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "function localDateStr(offsetDays) {",
                "  var d = new Date();",
                "  d.setDate(d.getDate() + offsetDays);",
                "  var y = d.getFullYear();",
                "  var m = String(d.getMonth() + 1).padStart(2, '0');",
                "  var day = String(d.getDate()).padStart(2, '0');",
                "  return y + '-' + m + '-' + day;",
                "}",
                "if (pm.response.code === 200) {",
                "  var json = pm.response.json();",
                "  if (json.token) pm.collectionVariables.set('staffToken', json.token);",
                "  if (json.userId) pm.collectionVariables.set('userId', json.userId);",
                "  if (json.linkedProfileId) pm.collectionVariables.set('linkedProfileId', json.linkedProfileId);",
                "  pm.collectionVariables.set('scheduleDate', localDateStr(0));",
                "  pm.collectionVariables.set('scheduleFrom', localDateStr(0));",
                "  pm.collectionVariables.set('scheduleTo', localDateStr(7));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{staffPhone}}\",\n  \"otp\": \"PASTE_OTP_FROM_LOGS\"\n}" },
            "url": "{{baseUrl}}/api/staff/auth/verify-otp"
          }
        }
      ]
    },
