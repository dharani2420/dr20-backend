        {
          "name": "3. Dashboard (READ)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var json = pm.response.json();",
                "  if (json.upcomingAppointments && json.upcomingAppointments.length > 0) {",
                "    pm.collectionVariables.set('appointmentId', json.upcomingAppointments[0].id);",
                "  }",
                "}"
              ],
